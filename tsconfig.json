{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "es2019",
    "moduleResolution": "node",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,

    "types": ["node", "jest"],

    "ignoreDeprecations": "6.0"
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules"]
}